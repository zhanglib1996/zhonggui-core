# zhonggui-core 环境变量模板
# 复制此文件为 .env 并填入实际值

# ─── 服务器 ───
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───
# ⚠️ 必须用 127.0.0.1，不要用 localhost
PG_HOST=127.0.0.1
PG_PORT=5433
PG_DATABASE=zhonggui_core
PG_USER=zhonggui
PG_PASSWORD=your_postgres_password_here

# ─── Valkey ───
# ⚠️ 必须用 127.0.0.1，不要用 localhost
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6380

# ─── LLM API ───
MODEL_NAME=mimo-v2.5-pro
MODEL_PROVIDER=openai
MODEL_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MODEL_API_KEY=your_api_key_here

# ─── 备用模型 (可选) ───
LLM_FALLBACK_MODEL=mimo-v2.5
LLM_FALLBACK_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_FALLBACK_API_KEY=your_api_key_here

# ─── JWT ───
# ⚠️ 生产环境必须修改!
JWT_SECRET=your_jwt_secret_here_at_least_32_chars
REFRESH_SECRET=your_refresh_secret_here_at_least_32_chars

# ─── 开发调试 ───
# 生产环境设为 false
DEV_AUTH_BYPASS=*** ─── 管理员用户 ───
# 逗号分隔
ADMIN_USERS=admin
